FROM nginx:alpine

# Copy custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy app frontend files
COPY frontend/ /usr/share/nginx/html/

# Copy marketing site files
COPY marketing/ /usr/share/nginx/marketing/

# Share fonts from app into marketing site
RUN cp -r /usr/share/nginx/html/fonts /usr/share/nginx/marketing/fonts

# Expose port 80
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
