<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Simple, clean shuttlecock like emoji 🏸 -->
    <group
        android:scaleX="0.7"
        android:scaleY="0.7"
        android:translateX="16"
        android:translateY="16">

        <!-- White feather cone -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 54,25
                           L 40,70
                           L 68,70
                           Z" />

        <!-- Feather segments (simple vertical lines) -->
        <path
            android:strokeWidth="2"
            android:strokeColor="#E0E0E0"
            android:pathData="M 46,35 L 43,70
                           M 50,30 L 48,70
                           M 54,25 L 54,70
                           M 58,30 L 60,70
                           M 62,35 L 65,70" />

        <!-- Red cork base (rounded) -->
        <ellipse
            android:fillColor="#E94560"
            android:pathData="M 38,70
                           Q 38,75 40,78
                           Q 45,82 54,82
                           Q 63,82 68,78
                           Q 70,75 70,70
                           Z" />

        <!-- Cork bottom circle -->
        <ellipse
            android:fillColor="#D63851"
            cx="54"
            cy="70"
            rx="16"
            ry="4" />

        <!-- Cork shine -->
        <ellipse
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.4"
            cx="50"
            cy="74"
            rx="4"
            ry="3" />
    </group>
</vector>
